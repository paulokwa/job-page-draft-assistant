# ── OS / Editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# ── IDE / Editor configs ─────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── Node (if you ever add a build step) ──────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ── Build / dist output ───────────────────────────────────────────────────────
dist/
build/
out/
*.zip
*.crx
*.pem

# ── Environment / secrets ─────────────────────────────────────────────────────
# API keys must NEVER be committed.
# The extension stores them in chrome.storage.sync (user settings), not in code.
.env
.env.*
*.env
secrets.json
config.local.js
config.local.json

# ── Test / coverage ───────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
